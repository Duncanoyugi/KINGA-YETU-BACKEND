### Base URL
@baseUrl = http://localhost:3000/api/auth

# =======================
# 1. Register User
# =======================
POST {{baseUrl}}/register
Content-Type: application/json

{
  "fullName": "Duncan Ochieng",
  "email": "admin.duncan2026@example.com",
  "password": "Admin@12345",
  "phoneNumber": "+254711000111",
  "role": "ADMIN",
  "dateOfBirth": "1995-06-15",
  "gender": "MALE",
  "county": "Nairobi",
  "subCounty": "Westlands",
  "address": "Westlands Office Block A",
  "idNumber": "34567890",
  "emergencyContact": "Peter Ochieng",
  "emergencyPhone": "+254722111222",
  "acceptTerms": true
}

### 
# 2. Verify Email OTP
# Replace OTP_CODE with the code you received in email
POST {{baseUrl}}/verify-email
Content-Type: application/json

{
  "email": "vin@gmail.com",
  "otpCode": "858674"
}

###
# 3. Login User
POST {{baseUrl}}/login
Content-Type: application/json

{
  "email": "Pheny.onyango2026@example.com",
  "password": "NewPass@123"
}

###
# 4. Refresh Token
# Replace REFRESH_TOKEN with the refresh token from login response
POST {{baseUrl}}/refresh
Content-Type: application/json

{
  "refreshToken": "REFRESH_TOKEN"
}

###
# 5. Change Password
# Replace ACCESS_TOKEN with the access token from login
PATCH {{baseUrl}}/change-password
Content-Type: application/json
Authorization: Bearer ACCESS_TOKEN

{
  "currentPassword": "Password@123",
  "newPassword": "NewPass@123",
  "confirmNewPassword": "NewPass@123"
}

###
# 6. Logout Current Device
# Replace ACCESS_TOKEN with the access token from login
POST {{baseUrl}}/logout
Authorization: Bearer ACCESS_TOKEN

###
# 7. Logout All Devices
# Replace ACCESS_TOKEN with the access token from login
POST {{baseUrl}}/logout-all
Authorization: Bearer ACCESS_TOKEN

###
# 8. Request Password Reset
POST {{baseUrl}}/request-password-reset
Content-Type: application/json

{
  "email": "Pheny.onyango2026@example.com"
}

###
# 9. Reset Password with OTP
# Replace OTP_CODE with OTP from password reset email
POST {{baseUrl}}/reset-password
Content-Type: application/json

{
  "otpCode": "277128",
  "newPassword": "NewPass@123",
  "confirmNewPassword": "NewPass@123"
}
