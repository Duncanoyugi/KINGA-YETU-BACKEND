generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum UserRole {
  PARENT
  HEALTH_WORKER
  ADMIN
  SUPER_ADMIN
}

enum OtpType {
  EMAIL_VERIFICATION
  PHONE_VERIFICATION
  PASSWORD_RESET
  REGISTRATION
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum HealthFacilityType {
  HOSPITAL
  HEALTH_CENTER
  CLINIC
  DISPENSARY
  Maternity
}

enum ImmunizationStatus {
  SCHEDULED
  ADMINISTERED
  MISSED
  DEFERRED
  CONTRAINDICATED
}

enum ScheduleStatus {
  PENDING
  SCHEDULED
  COMPLETED
  MISSED
  CONTRAINDICATED
  CANCELLED
}

enum ReminderType {
  VACCINE_DUE
  VACCINE_OVERDUE
  APPOINTMENT
  GENERAL
  EMAIL
  SMS
  PUSH
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum NotificationType {
  REMINDER
  ALERT
  UPDATE
  SYSTEM
  VACCINE_REMINDER
  APPOINTMENT_CONFIRMATION
  REPORT_READY
  SYSTEM_ALERT
  SECURITY_ALERT
  PUSH_NOTIFICATION
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
}

enum ReportType {
  COVERAGE
  IMMUNIZATION
  MISSED_VACCINES
  FACILITY_PERFORMANCE
  FACILITY
  CUSTOM
  DEMOGRAPHIC
  TIMELINESS
}

enum ReportFormat {
  PDF
  EXCEL
  CSV
  HTML
}

enum ReportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ReportFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  ON_DEMAND
}

// Models
model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  phoneNumber        String?             @unique
  password           String
  fullName           String
  role               UserRole            @default(PARENT)
  isActive           Boolean             @default(true)
  isEmailVerified    Boolean             @default(false)
  isPhoneVerified    Boolean             @default(false)
  lastLoginAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  
  // Notification preferences
  emailNotifications Boolean             @default(true)
  smsNotifications   Boolean             @default(true)
  pushNotifications  Boolean             @default(true)
  quietHoursStart    String?             @default("22:00")
  quietHoursEnd      String?             @default("07:00")
  reminderDays       Int[]               @default([7, 3, 1])
  adminProfile       AdminProfile?
  auditLogs          AuditLog[]
  healthWorker       HealthWorker?
  notifications      Notification[]
  parentProfile      Parent?
  reports            Report[]            @relation("ReportUser")
  generatedReports   Report[]            @relation("ReportGeneratedBy")
  sessions           Session[]
  profile            UserProfile?

  @@index([email])
  @@index([createdAt])
  @@map("users")
}

model Otp {
  id        String   @id @default(cuid())
  email     String?
  phone     String?
  code      String
  type      OtpType
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  metadata  String?  @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
  @@map("otps")
}

model UserProfile {
  id             String    @id @default(cuid())
  userId         String    @unique
  dateOfBirth    DateTime?
  gender         Gender?
  profilePicture String?
  address        String?
  county         String?
  subCounty      String?
  ward           String?
  idNumber       String?   @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Parent {
  id               String     @id @default(cuid())
  userId           String     @unique
  emergencyContact String?
  emergencyPhone   String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  children         Child[]
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminders        Reminder[]
  schedules        VaccinationSchedule[]

  @@map("parents")
}

model HealthWorker {
  id             String          @id @default(cuid())
  userId         String          @unique
  licenseNumber  String?         @unique
  qualification  String?
  specialization String?
  facilityId     String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  facility       HealthFacility? @relation(fields: [facilityId], references: [id])
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  immunizations  Immunization[]

  @@map("health_workers")
}

model AdminProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  department  String?
  permissions String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_profiles")
}

model HealthFacility {
  id            String             @id @default(cuid())
  name          String
  type          HealthFacilityType
  code          String             @unique
  mflCode       String?            @unique
  county        String
  subCounty     String
  ward          String?
  address       String?
  phone         String?
  email         String?
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  children      Child[]
  healthWorkers HealthWorker[]
  immunizations Immunization[]

  @@index([county, subCounty])
  @@map("health_facilities")
}

model Child {
  id                 String                @id @default(cuid())
  parentId           String
  firstName          String
  middleName         String?
  lastName           String
  dateOfBirth        DateTime
  gender             Gender
  birthCertificateNo String?               @unique
  uniqueIdentifier   String                @default(cuid())
  birthFacilityId    String?
  birthWeight        Float?
  birthHeight        Float?
  deliveryMethod     String?
  gestationalAge     String?
  complications      String?
  notes              String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  birthFacility      HealthFacility?       @relation(fields: [birthFacilityId], references: [id])
  parent             Parent                @relation(fields: [parentId], references: [id], onDelete: Cascade)
  developmentRecords DevelopmentRecord[]
  growthRecords      GrowthRecord[]
  immunizations      Immunization[]
  reminders          Reminder[]
  schedules          VaccinationSchedule[]

  @@index([parentId])
  @@index([dateOfBirth])
  @@index([birthCertificateNo])
  @@map("children")
}

model Vaccine {
  id                 String                @id @default(cuid())
  code               String                @unique
  name               String
  description        String?
  administrationRoute String?
  administrationSite  String?
  dosage              String?
  dosesRequired       String?
  sideEffects         String?
  manufacturer        String?
  contraindications   String?
  vaccineType        String?
  storageRequirements String?
  diseasePrevented   String?
  recommendedAgeDays Int
  minAgeDays         Int?
  maxAgeDays         Int?
  isBirthDose        Boolean               @default(false)
  isBooster          Boolean               @default(false)
  isActive           Boolean               @default(true)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  immunizations      Immunization[]
  reminders          Reminder[]
  schedules          VaccinationSchedule[]

  @@index([code])
  @@index([recommendedAgeDays])
  @@map("vaccines")
}

model Immunization {
  id               String            @id @default(cuid())
  childId          String
  vaccineId        String
  healthWorkerId   String?
  facilityId       String?
  ageAtDays        Int?
  dateAdministered DateTime          @default(now())
  status           ImmunizationStatus @default(SCHEDULED)
  batchNumber      String?
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  child            Child             @relation(fields: [childId], references: [id], onDelete: Cascade)
  vaccine          Vaccine           @relation(fields: [vaccineId], references: [id])
  healthWorker     HealthWorker?     @relation(fields: [healthWorkerId], references: [id])
  facility         HealthFacility?   @relation(fields: [facilityId], references: [id])

  @@index([childId])
  @@index([vaccineId])
  @@index([dateAdministered])
  @@map("immunizations")
}

model VaccinationSchedule {
  id        String        @id @default(cuid())
  childId   String
  parentId  String
  vaccineId String
  dueDate   DateTime
  status    ScheduleStatus @default(PENDING)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  child     Child          @relation(fields: [childId], references: [id], onDelete: Cascade)
  vaccine   Vaccine        @relation(fields: [vaccineId], references: [id])
  parent    Parent         @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@index([dueDate])
  @@map("vaccination_schedules")
}

model Reminder {
  id           String        @id @default(cuid())
  childId      String?
  parentId     String?
  vaccineId    String?
  type         ReminderType
  message      String
  scheduledFor DateTime
  status       ReminderStatus @default(PENDING)
  metadata     String?       @default("{}")
  retryCount   Int           @default(0)
  batchNumber  String?
  errorMessage String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  child        Child?        @relation(fields: [childId], references: [id], onDelete: Cascade)
  parent       Parent?       @relation(fields: [parentId], references: [id], onDelete: Cascade)
  vaccine      Vaccine?      @relation(fields: [vaccineId], references: [id])

  @@index([childId])
  @@index([parentId])
  @@index([scheduledFor])
  @@map("reminders")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  data      String?          @default("{}")
  isRead    Boolean          @default(false)
  sentAt    DateTime         @default(now())
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([sentAt])
  @@map("notifications")
}

model GrowthRecord {
  id              String   @id @default(cuid())
  childId         String
  measurementDate DateTime @default(now())
  weight          Float
  height          Float?
  headCircumference Float?
  muac            Float?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  child           Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@index([measurementDate])
  @@map("growth_records")
}

model DevelopmentRecord {
  id                String   @id @default(cuid())
  childId           String
  assessmentDate    DateTime @default(now())
  milestoneType     String
  status            String
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  child             Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@index([assessmentDate])
  @@map("development_records")
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  action     AuditAction
  entityType String
  entityId   String?
  oldData    String?
  newData    String?
  createdAt  DateTime    @default(now())
  user       User?       @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([entityType])
  @@index([userId])
  @@map("audit_logs")
}

model Report {
  id          String       @id @default(cuid())
  userId      String
  type        ReportType
  title       String
  description String?
  status      ReportStatus @default(PENDING)
  fileUrl     String?
  metadata    String?     @default("{}")
  parameters  String?     @default("{}")
  data        String?     @default("{}")
  isPublic    Boolean     @default(false)
  generatedAt DateTime?   @default(now())
  generatedById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation("ReportUser", fields: [userId], references: [id], onDelete: Cascade)
  generatedBy User?        @relation("ReportGeneratedBy", fields: [generatedById], references: [id])

  @@index([userId])
  @@map("reports")
}
